# 浏览器端请求基址（开发走 Nuxt 代理，生产一般为 /api）
NUXT_PUBLIC_API_BASE=/api

# Live2D 看板娘 wl-live2d（设为 false 关闭）
# 文档：https://live2d.doc.nianian.cn/
NUXT_PUBLIC_LIVE2D_ENABLED=true

# SSR 服务端请求基址（需能直连 Go API）
NUXT_API_BASE=http://127.0.0.1:8080/api

# PM2 / 生产启动（scripts/pm2-start.mjs、ecosystem.config.cjs）
# HOST=0.0.0.0
# PORT=3000

# Docker 部署见 deploy/ 与 .github/workflows/deploy.yml
# GHCR 镜像: ghcr.io/xszs12138/blog:v1.0.0
# 发版: git tag v1.0.0 && git push origin v1.0.0
